{
  "name": "engineering-blueprinter",
  "version": "0.1.0",
  "description": "A provider-agnostic interface specification for AI-assisted backend development. 108 domain contracts, 83 adapters, code generation.",
  "keywords": [
    "contract",
    "domain",
    "backend",
    "ai",
    "code-generation",
    "adapter",
    "registry"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js"
  },
  "bin": {
    "blueprinter": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/core/*.test.js dist/core/adapters/*.test.js dist/mcp/*.test.js",
    "test:integration": "npm run build && bash scripts/integration-test.sh",
    "postinstall": "npm run build",
    "link": "npm run build && npm link"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/handlebars": "^4.0.40",
    "handlebars": "^4.7.9",
    "yaml": "^2.9.0"
  }
}
