{
  "name": "@friehub/blueprint",
  "version": "0.2.0",
  "description": "A domain contract catalogue for backend development. 155 module contracts, 83 adapters, 5 languages, AI-ready via 12 MCP tools.",
  "keywords": ["contract", "domain", "backend", "code-generation", "adapter", "blueprint", "ai", "mcp"],
  "license": "MIT",
  "author": "Friehub",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/friehub/engineering-blueprinter.git"
  },
  "bugs": {
    "url": "https://github.com/friehub/engineering-blueprinter/issues"
  },
  "homepage": "https://github.com/friehub/engineering-blueprinter#readme",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "blueprint": "./dist/cli.js",
    "blueprinter": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "schemas/",
    "completions/",
    "scripts/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/build-catalog.cjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit --strict",
    "test": "npx tsx --test 'src/**/*.test.ts'",
    "test:mcp": "npx tsx --test 'src/mcp/*.test.ts'",
    "precommit": "bash scripts/pre-commit.sh",
    "check:publish": "bash scripts/check-publish.sh",
    "test:integration": "npm run build && bash scripts/integration-test.sh",
    "prerelease": "npm run build && bash scripts/pre-commit.sh",
    "link": "npm run build && npm link"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/handlebars": "^4.0.40",
    "handlebars": "^4.7.9",
    "yaml": "^2.9.0"
  }
}
