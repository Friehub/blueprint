  "blueprint": {
    "catalogHash": "d950fd32371e9444e66e814f03cc0adf6f99acefcf48a2da6d7f413ac987309d"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/build-catalog.cjs && node scripts/strip-catalog.cjs && node scripts/extract-entities.cjs && node scripts/hash-catalog.cjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit --strict",
    "test": "node --test \"dist/**/*.test.js\"",
    "test:mcp": "node --test 'dist/mcp/*.test.js'",
    "precommit": "bash scripts/pre-commit.sh",
    "check:publish": "bash scripts/check-publish.sh",
    "test:integration": "npm run build && bash scripts/integration-test.sh",
    "prerelease": "npm run build && bash scripts/pre-commit.sh",
    "link": "npm run build && npm link",
    "docs": "npm run build && cp dist/catalog.json site/public/catalog.json && cp dist/entities.json site/public/entities.json && cd site && npm ci && npx vite build"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/handlebars": "^4.0.40",
    "handlebars": "^4.7.9",
    "yaml": "^2.9.0"
  }
